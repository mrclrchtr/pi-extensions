{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true
  },
  "include": ["aliases/**/*.ts", "bash-timeout/**/*.ts", "skill-shortcut/**/*.ts", "lsp/**/*.ts"],
  "exclude": ["node_modules", "lsp/__tests__"]
}
